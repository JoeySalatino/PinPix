rules_version = '2';

// ============================================================
// PinPix Cloud Storage security rules
// ------------------------------------------------------------
// Buckets used by the app:
//   /spots/{filename}                 - spot photo, filename is `${uid}_${ts}.jpg`
//   /profilePictures/{uid}.jpg        - the user's profile picture
//
// Default deny everything else.
// ============================================================

service firebase.storage {
  match /b/{bucket}/o {

    // --------------------------------------------------------
    // /spots/{filename}
    // The app uploads as `spots/${user.uid}_${Date.now()}.jpg`.
    // We enforce that the filename starts with the caller's uid so
    // a user cannot upload to someone else's "namespace".
    // --------------------------------------------------------
    match /spots/{filename} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && filename.matches('^' + request.auth.uid + '_.*\\.jpg$')
        && request.resource.size < 10 * 1024 * 1024  // 10 MB cap
        && request.resource.contentType.matches('image/.*');

      // Only the owner (by filename prefix) can delete.
      allow delete: if request.auth != null
        && filename.matches('^' + request.auth.uid + '_.*');

      // No updates — overwrite with a new upload is fine, but
      // overwriting an existing object in place is not.
      allow update: if false;
    }

    // --------------------------------------------------------
    // /profilePictures/{uid}.jpg
    // --------------------------------------------------------
    match /profilePictures/{fileName} {
      allow read: if request.auth != null;

      // Allow create or overwrite of your own profile picture.
      allow write: if request.auth != null
        && fileName == request.auth.uid + '.jpg'
        && (request.resource == null
            || (request.resource.size < 5 * 1024 * 1024
                && request.resource.contentType.matches('image/.*')));
    }
  }
}
